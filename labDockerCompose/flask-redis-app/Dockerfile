# syntax=docker/dockerfile:1
# Указываем версию синтаксиса Dockerfile

# Базовый образ: официальный образ Python 3.10 на базе Alpine Linux
FROM python:3.10-alpine

# Устанавливаем рабочую директорию внутри контейнера
# Все последующие команды будут выполняться в /code
WORKDIR /code

# Устанавливаем переменные окружения
# FLASK_APP - указывает Flask, какой файл запускать
ENV FLASK_APP=app.py
# FLASK_RUN_HOST - заставляет Flask слушать все сетевые интерфейсы
# (без этого приложение будет доступно только внутри контейнера)
ENV FLASK_RUN_HOST=0.0.0.0

# Устанавливаем системные зависимости через пакетный менеджер Alpine (apk)
# --no-cache - не сохранять кэш пакетов (для уменьшения размера образа)
# gcc, musl-dev, linux-headers - необходимы для компиляции некоторых Python пакетов
RUN apk add --no-cache gcc musl-dev linux-headers

# Копируем файл с зависимостями Python в контейнер
# Это делается ДО копирования всего приложения для использования кэша Docker
COPY requirements.txt requirements.txt

# Устанавливаем Python-зависимости из requirements.txt
RUN pip install -r requirements.txt

# Указываем, что контейнер будет слушать порт 5000
# Это просто документация, реально порт открывается при запуске с -p
EXPOSE 5000

# Копируем код приложения в рабочую директорию
COPY app.py .

# Команда для запуска приложения
# Flask запускается в debug режиме (автоматически перезагружается при изменениях)
CMD ["flask", "run", "--debug"]
